{
  "version": "1.0",
  "description": "Core set registry for python PQC API reference",
  "python_image_build_schema": {
    "compatibility_semantics": "compatibility values are minimum Python requirements unless a closed range is explicitly provided",
    "default_base_image_pattern": "python:{python_version}-slim",
    "base_image_overrides": {
      "2.7": "python:2.7-slim"
    },
    "install": {
      "python_package_manager": "pip",
      "python_flags": [
        "--no-cache-dir"
      ],
      "upgrade_before_install": [
        "pip",
        "setuptools",
        "wheel"
      ]
    },
    "system_dependencies": {
      "common": [
        "build-essential",
        "gcc",
        "libffi-dev",
        "libssl-dev"
      ],
      "by_library": {
        "PyNaCl": [
          "libsodium-dev"
        ],
        "M2Crypto": [
          "swig",
          "libssl-dev"
        ]
      }
    },
    "selection_rules": {
      "only_include_python_versions_with_include_true": true,
      "skip_library_versions_with_empty_compatibility": true,
      "framework_dimension_optional": true
    },
    "validation": {
      "import_smoke_test": true,
      "minimum_runtime_healthcheck": "python -c \"import importlib; print('ok')\""
    }
  },
  "discovery_service": {
    "id": "pqc-discovery",
    "name": "PQC Discovery Service",
    "port": 4000,
    "description": "Master discovery service listing all available API endpoints"
  },
