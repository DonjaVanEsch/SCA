        },
        {
          "name": "crypto/rc4",
          "module": "built-in",
          "version": "built-in",
          "notes": "Fully broken stream cipher (NOMORE attack 2015, RC4 biases). Included as SCA detection reference — migration path: crypto/aes (AES-GCM) or xcrypto (ChaCha20-Poly1305)."
        },
        {
          "name": "crypto/elliptic",
          "module": "built-in",
          "version": "built-in",
          "notes": "ECC base package, deprecated for new use since Go 1.22. Not PQC-safe. Included as SCA detection reference — migration path: crypto/mlkem, circl (ML-KEM/X-Wing)."
        }
